{
  "name": "opencolaos",
  "module": "src/index.ts",
  "type": "module",
  "version": "0.1.0",
  "description": "OpenColaOS — The Open Source Agent Operating System",
  "bin": {
    "opencolaos": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/server/index.ts",
    "chat": "bun run src/cli/chat.ts",
    "web": "bun run src/server/index.ts",
    "cli": "bun run src/cli/index.ts",
    "dev": "bun --watch src/cli/chat.ts",
    "build": "bun build src/index.ts --outdir dist"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^11.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "date-fns": "^4.4.0",
    "nanoid": "3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
